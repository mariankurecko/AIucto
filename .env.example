# Workspace
AI_OS_CONFIG_DIR=./config
AI_OS_DEFAULT_WORKSPACE=marian-ai-os
AI_OS_LOG_LEVEL=info

# Google OAuth / token storage
GOOGLE_OAUTH_CLIENT_SECRET_FILE=/secure/path/google-client-secret.json
GOOGLE_TOKEN_STORE_DIR=/secure/path/google-tokens

# OpenRouter / document extraction
OPENROUTER_API_KEY=replace-me

# Never commit real credentials, tokens, or generated accounting data.
